{
  "name": "llm-now",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "llm-now": "./index.ts"
  },
  "scripts": {
    "start": "bun index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "runtime:smoke": "bun tests/runtime-compile-smoke.ts",
    "check": "bun test && bun run typecheck && bun run runtime:smoke",
    "build:native": "bun scripts/build.ts",
    "release:validate": "bun scripts/release-validate.ts"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/bun": "1.3.14",
    "fflate": "0.8.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "@swartzrock/byok-runtime": "2.1.0",
    "picocolors": "1.1.1"
  }
}
